new file mode 100644
index 0000000000000000000000000000000000000000..f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5
--- /dev/null
+++ b/src/main/java/dev/hikari/util/region/RegionHeatmap.java
@@ -0,0 +1,228 @@
+package dev.hikari.util.region;
+
+import it.unimi.dsi.fastutil.longs.Long2IntMap;
+import it.unimi.dsi.fastutil.longs.Long2IntOpenHashMap;
+import it.unimi.dsi.fastutil.longs.Long2LongMap;
+import it.unimi.dsi.fastutil.longs.Long2LongOpenHashMap;
+import net.minecraft.core.BlockPos;
+import net.minecraft.server.level.ServerLevel;
+import net.minecraft.server.level.ServerPlayer;
+import net.minecraft.world.level.ChunkPos;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+import java.util.List;
+
+/**
+ * Тепловая карта чанков мира.
+ *
+ * Каждый чанк имеет "температуру" от 0 (холодный) до 3 (горячий):
+ * - HOT (3): Рядом с игроком (simulation distance) — полный тик
+ * - WARM (2): В пределах view distance — визуально загружен, редкий тик
+ * - COOL (1): Дальше view distance но загружен — минимальный тик
+ * - COLD (0): Форсированно загружен — пропуск тиков
+ *
+ * Температура обновляется каждые HEATMAP_UPDATE_INTERVAL тиков.
+ */
+public final class RegionHeatmap {
+
+    private static final Logger LOGGER = LoggerFactory.getLogger(RegionHeatmap.class);
+
+    // Конфигурация
+    public static int HEATMAP_UPDATE_INTERVAL = 20; // Тиков между обновлениями
+    public static int HOT_RADIUS = 3;   // Чанков вокруг игрока для HOT
+    public static int WARM_RADIUS = 6;  // Чанков для WARM
+
+    // Уровни температуры
+    public static final int COLD = 0;
+    public static final int COOL = 1;
+    public static final int WARM = 2;
+    public static final int HOT = 3;
+
+    // Хранилище температур: ключ = chunkPos.toLong(), значение = температура
+    private final Long2IntMap chunkHeat = new Long2IntOpenHashMap(256, 0.75f);
+    // Время последнего доступа (для cleanup)
+    private final Long2LongMap lastAccessTime = new Long2LongOpenHashMap(256, 0.75f);
+    
+    private int ticksUntilUpdate = 0;
+    private long currentTick = 0;
+
+    // Статистика
+    public int hotChunks = 0;
+    public int warmChunks = 0;
+    public int coolChunks = 0;
+    public int coldChunks = 0;
+
+    public RegionHeatmap() {
+        chunkHeat.defaultReturnValue(COLD); // По умолчанию холодно
+    }
+
+    /**
+     * Обновляет тепловую карту на основе позиций игроков.
+     * Вызывается раз в HEATMAP_UPDATE_INTERVAL тиков.
+     */
+    public void update(ServerLevel level, long tick) {
+        if (--ticksUntilUpdate > 0) return;
+        ticksUntilUpdate = HEATMAP_UPDATE_INTERVAL;
+        currentTick = tick;
+
+        // Сбрасываем все чанки к COLD
+        // Оптимизация: вместо полного сброса — обновляем инкрементально
+        List<ServerPlayer> players = level.players();
+        
+        // Временный сброс к COOL (не COLD, чтобы не потерять важные чанки)
+        chunkHeat.replaceAll((chunkKey, oldHeat) -> {
+            lastAccessTime.put(chunkKey, tick);
+            return Math.max(oldHeat - 1, COOL);
+        });
+
+        // Нагреваем чанки рядом с игроками
+        for (ServerPlayer player : players) {
+            ChunkPos playerChunk = player.chunkPosition();
+            
+            // HOT зона (рядом с игроком)
+            for (int dx = -HOT_RADIUS; dx <= HOT_RADIUS; dx++) {
+                for (int dz = -HOT_RADIUS; dz <= HOT_RADIUS; dz++) {
+                    long key = ChunkPos.asLong(playerChunk.x + dx, playerChunk.z + dz);
+                    chunkHeat.put(key, HOT);
+                    lastAccessTime.put(key, tick);
+                }
+            }
+
+            // WARM зона
+            for (int dx = -WARM_RADIUS; dx <= WARM_RADIUS; dx++) {
+                for (int dz = -WARM_RADIUS; dz <= WARM_RADIUS; dz++) {
+                    if (Math.abs(dx) <= HOT_RADIUS && Math.abs(dz) <= HOT_RADIUS) continue;
+                    long key = ChunkPos.asLong(playerChunk.x + dx, playerChunk.z + dz);
+                    int current = chunkHeat.get(key);
+                    if (current < WARM) {
+                        chunkHeat.put(key, WARM);
+                        lastAccessTime.put(key, tick);
+                    }
+                }
+            }
+        }
+
+        // Cleanup старых записей (старше 5 минут)
+        long cutoffTick = tick - 6000;
+        chunkHeat.long2IntEntrySet().removeIf(entry -> {
+            long lastAccess = lastAccessTime.getOrDefault(entry.getLongKey(), 0L);
+            return lastAccess < cutoffTick;
+        });
+        lastAccessTime.long2LongEntrySet().removeIf(entry -> entry.getLongValue() < cutoffTick);
+
+        // Подсчёт статистики
+        countStats();
+    }
+
+    /**
+     * Получает температуру чанка.
+     */
+    public int getChunkHeat(ChunkPos pos) {
+        return chunkHeat.getOrDefault(pos.toLong(), COLD);
+    }
+
+    public int getChunkHeat(long chunkKey) {
+        return chunkHeat.getOrDefault(chunkKey, COLD);
+    }
+
+    /**
+     * Должен ли чанк тикать в данном тике.
+     */
+    public boolean shouldTickChunk(ChunkPos pos, long tick) {
+        int heat = getChunkHeat(pos);
+        return switch (heat) {
+            case HOT -> true;   // Всегда тикаем
+            case WARM -> (tick % 2) == 0; // Через тик
+            case COOL -> (tick % 4) == 0; // Каждый 4-й
+            case COLD -> (tick % 8) == 0; // Каждый 8-й
+            default -> true;
+        };
+    }
+
+    /**
+     * Должны ли tile entities тикать в этом чанке.
+     */
+    public boolean shouldTickBlockEntities(ChunkPos pos, long tick) {
+        int heat = getChunkHeat(pos);
+        return switch (heat) {
+            case HOT -> true;
+            case WARM -> (tick % 2) == 0;
+            case COOL -> (tick % 5) == 0;
+            case COLD -> (tick % 10) == 0;
+            default -> true;
+        };
+    }
+
+    /**
+     * Получает effective tick rate для чанка (1.0 = каждый тик, 0.5 = каждый 2-й).
+     */
+    public double getEffectiveTickRate(ChunkPos pos) {
+        return switch (getChunkHeat(pos)) {
+            case HOT -> 1.0;
+            case WARM -> 0.5;
+            case COOL -> 0.25;
+            case COLD -> 0.125;
+            default -> 1.0;
+        };
+    }
+
+    private void countStats() {
+        hotChunks = 0; warmChunks = 0; coolChunks = 0; coldChunks = 0;
+        for (int heat : chunkHeat.values()) {
+            switch (heat) {
+                case HOT -> hotChunks++;
+                case WARM -> warmChunks++;
+                case COOL -> coolChunks++;
+                default -> coldChunks++;
+            }
+        }
+    }
+
+    public int getTotalTrackedChunks() {
+        return chunkHeat.size();
+    }
+
+    public void clear() {
+        chunkHeat.clear();
+        lastAccessTime.clear();
+    }
+
+    @Override
+    public String toString() {
+        return String.format("RegionHeatmap[HOT=%d, WARM=%d, COOL=%d, COLD=%d, total=%d]",
+            hotChunks, warmChunks, coolChunks, coldChunks, getTotalTrackedChunks());
+    }
+}
diff --git a/src/main/java/dev/hikari/util/region/IncrementalTickScheduler.java b/src/main/java/dev/hikari/util/region/IncrementalTickScheduler.java
new file mode 100644
index 0000000000000000000000000000000000000000..g7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6
--- /dev/null
+++ b/src/main/java/dev/hikari/util/region/IncrementalTickScheduler.java
@@ -0,0 +1,142 @@
+package dev.hikari.util.region;
+
+import it.unimi.dsi.fastutil.ints.Int2IntMap;
+import it.unimi.dsi.fastutil.ints.Int2IntOpenHashMap;
+import net.minecraft.core.BlockPos;
+import net.minecraft.server.level.ServerLevel;
+import net.minecraft.world.level.ChunkPos;
+import net.minecraft.world.level.block.entity.BlockEntity;
+import net.minecraft.world.level.block.entity.TickingBlockEntity;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+/**
+ * Инкрементальный планировщик тиков для tile entities.
+ *
+ * Работает вместе с RegionHeatmap для пропуска тиков
+ * "холодных" tile entities. Каждый тип tile entity
+ * имеет свой minimum tick interval для безопасности.
+ */
+public final class IncrementalTickScheduler {
+
+    private static final Logger LOGGER = LoggerFactory.getLogger(IncrementalTickScheduler.class);
+
+    // Минимальные интервалы для разных типов tile entities (в тиках)
+    // Это защита от поломки механизмов при пропуске тиков
+    private static final Int2IntMap MIN_INTERVALS = new Int2IntOpenHashMap();
+    
+    static {
+        // Критичные — никогда не пропускаем
+        MIN_INTERVALS.defaultReturnValue(1);
+        
+        // Hoppers — можно пропускать (они имеют cooldown)
+        // Но слишком редко = медленные сортировки
+        MIN_INTERVALS.put(getTypeId("hopper"), 1);
+        
+        // Furnaces — умеренно, иначе медленная плавка
+        MIN_INTERVALS.put(getTypeId("furnace"), 2);
+        MIN_INTERVALS.put(getTypeId("blast_furnace"), 2);
+        MIN_INTERVALS.put(getTypeId("smoker"), 2);
+        
+        // Chests — можно реже (только для обновления viewers)
+        MIN_INTERVALS.put(getTypeId("chest"), 10);
+        MIN_INTERVALS.put(getTypeId("trapped_chest"), 10);
+        MIN_INTERVALS.put(getTypeId("ender_chest"), 20);
+        
+        // Brewing stand — редко, зелья варятся долго
+        MIN_INTERVALS.put(getTypeId("brewing_stand"), 4);
+        
+        // Beacon — эффекты обновляются редко
+        MIN_INTERVALS.put(getTypeId("beacon"), 80);
+        
+        // Spawner — зависит от spawn rate, обычно редко
+        MIN_INTERVALS.put(getTypeId("mob_spawner"), 10);
+        
+        // Signs — почти не нуждаются в тиках
+        MIN_INTERVALS.put(getTypeId("sign"), 200);
+        MIN_INTERVALS.put(getTypeId("hanging_sign"), 200);
+        
+        // Skull — только частицы
+        MIN_INTERVALS.put(getTypeId("skull"), 100);
+        
+        // Banner — статичны
+        MIN_INTERVALS.put(getTypeId("banner"), 200);
+        
+        // Dispenser/Dropper — активны только при редстоуне
+        MIN_INTERVALS.put(getTypeId("dispenser"), 4);
+        MIN_INTERVALS.put(getTypeId("dropper"), 4);
+        
+        // Note block — только при активации
+        MIN_INTERVALS.put(getTypeId("noteblock"), 20);
+        
+        // Jukebox — редко
+        MIN_INTERVALS.put(getTypeId("jukebox"), 40);
+        
+        // Lectern — редко
+        MIN_INTERVALS.put(getTypeId("lectern"), 20);
+        
+        // Daylight detector — достаточно редко
+        MIN_INTERVALS.put(getTypeId("daylight_detector"), 20);
+        
+        // Comparator — может быть частым при редстоуне
+        MIN_INTERVALS.put(getTypeId("comparator"), 2);
+        
+        // Sculk — новые блоки, умеренно
+        MIN_INTERVALS.put(getTypeId("sculk_sensor"), 2);
+        MIN_INTERVALS.put(getTypeId("sculk_catalyst"), 4);
+        MIN_INTERVALS.put(getTypeId("sculk_shrieker"), 4);
+    }
+
+    // Храним tick counters для каждого block entity по позиции
+    private final Int2IntMap entityTickCounters = new Int2IntOpenHashMap(256, 0.75f);
+
+    private static int getTypeId(String type) {
+        return type.hashCode();
+    }
+
+    /**
+     * Определяет, должен ли tile entity тикать.
+     *
+     * @param blockEntity   tile entity
+     * @param chunkHeat     температура чанка
+     * @param worldTick     текущий тик мира
+     * @return true если должен тикать
+     */
+    public boolean shouldTickBlockEntity(BlockEntity blockEntity, int chunkHeat, long worldTick) {
+        BlockPos pos = blockEntity.getBlockPos();
+        int posHash = pos.hashCode();
+        
+        int minInterval = getMinInterval(blockEntity);
+        int tickCounter = entityTickCounters.getOrDefault(posHash, 0) + 1;
+        entityTickCounters.put(posHash, tickCounter);
+
+        // Базовый интервал + модификатор температуры
+        int effectiveInterval = minInterval;
+        effectiveInterval *= switch (chunkHeat) {
+            case RegionHeatmap.HOT -> 1;
+            case RegionHeatmap.WARM -> 2;
+            case RegionHeatmap.COOL -> 4;
+            case RegionHeatmap.COLD -> 8;
+            default -> 1;
+        };
+
+        return (tickCounter % effectiveInterval) == 0;
+    }
+
+    /**
+     * Получает минимальный интервал для типа tile entity.
+     */
+    private int getMinInterval(BlockEntity blockEntity) {
+        String typeName = blockEntity.getType().toString().toLowerCase();
+        for (var entry : MIN_INTERVALS.int2IntEntrySet()) {
+            if (typeName.contains(String.valueOf(entry.getIntKey()))) {
+                return entry.getIntValue();
+            }
+        }
+        return MIN_INTERVALS.defaultReturnValue();
+    }
+
+    /**
+     * Очистка устаревших записей.
+     */
+    public void cleanup() {
+        // Удаляем записи старше 10 минут без обновления
+        // В реальности entityTickCounters будет расти — нужна периодическая очистка
+        if (entityTickCounters.size() > 10000) {
+            // При переполнении — сброс (не идеально, но безопасно)
+            entityTickCounters.clear();
+        }
+    }
+
+    public void clear() {
+        entityTickCounters.clear();
+    }
+
+    public int getTrackedBlockEntityCount() {
+        return entityTickCounters.size();
+    }
+}
