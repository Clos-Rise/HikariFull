         if (!this.brain.hasActivity(Activity.REST) && this.shouldRestock()) {
             this.restock();
         }
@@ -283,6 +327,7 @@ public class Villager extends AbstractVillager implements ReputationEventHandler
         this.updateTrades();
         this.level().getProfiler().pop();
     }
