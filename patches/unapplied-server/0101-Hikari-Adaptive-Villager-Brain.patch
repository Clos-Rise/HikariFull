     protected void customServerAiStep(ServerLevel worldserver) {
         this.level().getProfiler().push("villagerBrain");
         
+        // Hikari start - Adaptive Villager Brain
+        if (AdaptiveBrainController.ENABLED) {
+            boolean runFullBrain = hikariBrainController.shouldRunFullBrain(this, worldserver, 
+                this.tickCount);
+            
+            // Level 1 (Deep Lobotomy) — минимальная обработка
+            if (!runFullBrain && hikariBrainController.getCurrentLevel() == 
+                    AdaptiveBrainController.BrainLevel.DEEP_LOBOTOMY) {
+                
+                // Только ресток торговли и размножение
+                this.handleTradingRestock();
+                this.updateTrades();
+                
+                // Периодическая проверка на пробуждение
