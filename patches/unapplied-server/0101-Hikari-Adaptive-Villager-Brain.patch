new file mode 100644
index 0000000000000000000000000000000000000000..d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3
--- /dev/null
+++ b/src/main/java/dev/hikari/util/villager/PathfindingStats.java
@@ -0,0 +1,138 @@
+package dev.hikari.util.villager;
+
+import java.util.ArrayDeque;
+import java.util.Deque;
+
+/**
+ * Sliding window statistics для pathfinding операций villager.
+ *
+ * Отслеживает success/fail pathfinding с фиксированным окном
+ * для определения, стоит ли пытаться искать путь или
+ * перейти в более экономный режим.
+ */
+public final class PathfindingStats {
+
+    private static final int WINDOW_SIZE = 50; // Последние 50 попыток
+    private static final float SUCCESS_PROMOTE_THRESHOLD = 0.6f;  // 60% успеха -> Full Brain
+    private static final float FAIL_DEMOTE_THRESHOLD = 0.15f;     // 15% успеха -> Lobotomy
+    private static final int MIN_ATTEMPTS_BEFORE_DEMOTE = 20;     // Минимум попыток перед демоцией
+
+    private final Deque<Boolean> results = new ArrayDeque<>(WINDOW_SIZE);
+    private int successes = 0;
+    private int totalAttempts = 0;
+
+    /**
+     * Регистрирует результат попытки pathfinding.
+     */
+    public void recordAttempt(boolean success) {
+        if (results.size() >= WINDOW_SIZE) {
+            Boolean old = results.pollFirst();
+            if (old != null && old) {
+                successes--;
+            }
+        }
+        results.addLast(success);
+        if (success) {
+            successes++;
+        }
+        totalAttempts++;
+    }
+
+    /**
+     * Получает текущий success rate (0.0 - 1.0).
+     */
+    public float getSuccessRate() {
+        if (results.isEmpty()) return 0.5f; // Нейтральное значение
+        return (float) successes / results.size();
+    }
+
+    /**
+     * Должен ли villager быть повышен до Full Brain.
+     */
+    public boolean shouldPromote() {
+        if (results.size() < MIN_ATTEMPTS_BEFORE_DEMOTE) return false;
+        return getSuccessRate() >= SUCCESS_PROMOTE_THRESHOLD;
+    }
+
+    /**
+     * Должен ли villager быть понижен до Deep Lobotomy.
+     */
+    public boolean shouldDemote() {
+        if (results.size() < MIN_ATTEMPTS_BEFORE_DEMOTE) return false;
+        return getSuccessRate() <= FAIL_DEMOTE_THRESHOLD;
+    }
+
+    /**
+     * Достаточно ли данных для принятия решения.
+     */
+    public boolean hasEnoughData() {
+        return results.size() >= MIN_ATTEMPTS_BEFORE_DEMOTE;
+    }
+
+    /**
+     * Общее число попыток за всё время.
+     */
+    public int getTotalAttempts() {
+        return totalAttempts;
+    }
+
+    /**
+     * Очищает статистику (например, при изменении окружения).
+     */
+    public void reset() {
+        results.clear();
+        successes = 0;
+        totalAttempts = 0;
+    }
+
+    @Override
+    public String toString() {
+        return String.format("PathfindingStats[successRate=%.2f, attempts=%d, window=%d/%d]",
+            getSuccessRate(), totalAttempts, results.size(), WINDOW_SIZE);
+    }
+}
diff --git a/src/main/java/dev/hikari/util/villager/AdaptiveBrainController.java b/src/main/java/dev/hikari/util/villager/AdaptiveBrainController.java
new file mode 100644
index 0000000000000000000000000000000000000000..e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4
--- /dev/null
+++ b/src/main/java/dev/hikari/util/villager/AdaptiveBrainController.java
@@ -0,0 +1,268 @@
+package dev.hikari.util.villager;
+
+import net.minecraft.core.BlockPos;
+import net.minecraft.server.level.ServerLevel;
+import net.minecraft.world.entity.ai.memory.MemoryModuleType;
+import net.minecraft.world.entity.ai.navigation.PathNavigation;
+import net.minecraft.world.entity.npc.Villager;
+import net.minecraft.world.level.block.state.BlockState;
+import net.minecraft.world.entity.ai.Brain;
+import org.slf4j.Logger;
+import org.slf4j.LoggerFactory;
+
+import java.util.Optional;
+
+/**
+ * Адаптивный контроллер мозга жителя (HAVB).
+ *
+ * Управляет 3-мя уровнями активности мозга villager:
+ * - Level 3: Полноценный AI (свободное перемещение)
+ * - Level 2: Умное ожидание (редкий pathfinding, рабочий мозг)
+ * - Level 1: Глубокая лоботомия (торговля + размножение, без пути)
+ *
+ * Переходы между уровнями происходят автоматически на основе
+ * статистики успешности pathfinding.
+ */
+public final class AdaptiveBrainController {
+
+    private static final Logger LOGGER = LoggerFactory.getLogger(AdaptiveBrainController.class);
+
+    // Конфигурация
+    public static boolean ENABLED = true;
+    public static int TICK_INTERVAL_LEVEL2 = 20;    // Pathfinding каждые N тиков
+    public static int TICK_INTERVAL_LEVEL1 = 100;   // Проверка на пробуждение
+    public static int CHECK_INTERVAL = 5;            // Интервал проверки уровня
+
+    // Внутренние константы
+    private static final int STUCK_THRESHOLD = 60;   // Тиков без движения для Level 2
+    private static final int IDLE_THRESHOLD = 200;   // Тиков без движения для Level 1
+
+    public enum BrainLevel {
+        FULL_BRAIN(3),      // Полноценный AI
+        SMART_IDLE(2),      // Редкий pathfinding
+        DEEP_LOBOTOMY(1);   // Без pathfinding
+
+        private final int value;
+        BrainLevel(int value) { this.value = value; }
+        public int getValue() { return value; }
+    }
+
+    private BrainLevel currentLevel = BrainLevel.FULL_BRAIN;
+    private final PathfindingStats stats = new PathfindingStats();
+    private int ticksAtCurrentPos = 0;
+    private int ticksSinceLevelCheck = 0;
+    private BlockPos lastPosition = BlockPos.ZERO;
+    private boolean forceRecheck = false; // Флаг принудительной перепроверки
+
+    // Торговля и размножение работают на всех уровнях
+    private int tradeCooldown = 0;
+    private int lastRestockTick = 0;
+
+    /**
+     * Основной метод — вызывается каждый тик в customServerAiStep villager.
+     */
+    public boolean shouldRunFullBrain(Villager villager, ServerLevel level, int tickCount) {
+        if (!ENABLED) return true; // Если система отключена — полный AI
+
+        BlockPos currentPos = villager.blockPosition();
+        
+        // Отслеживаем время на одном месте
+        if (currentPos.equals(lastPosition)) {
+            ticksAtCurrentPos++;
+        } else {
+            ticksAtCurrentPos = 0;
+            if (currentLevel.ordinal() >= BrainLevel.SMART_IDLE.ordinal()) {
+                // Двинулся — возможно стоит повысить уровень
+                forceRecheck = true;
+            }
+        }
+        lastPosition = currentPos;
+
+        // Периодическая проверка уровня
+        if (++ticksSinceLevelCheck >= CHECK_INTERVAL || forceRecheck) {
+            ticksSinceLevelCheck = 0;
+            forceRecheck = false;
+            updateBrainLevel(villager, level);
+        }
+
+        return switch (currentLevel) {
+            case FULL_BRAIN -> true;  // Полный AI каждый тик
+            case SMART_IDLE -> (tickCount % TICK_INTERVAL_LEVEL2) == 0; // Редко
+            case DEEP_LOBOTOMY -> false; // Нет pathfinding, но разрешаем trade/breed
+        };
+    }
+
+    /**
+     * Определяет, должен ли Level 1 villager проверить возможность пробуждения.
+     */
+    public boolean shouldCheckWakeUp(int tickCount) {
+        if (currentLevel != BrainLevel.DEEP_LOBOTOMY) return false;
+        return (tickCount % TICK_INTERVAL_LEVEL1) == 0;
+    }
+
+    /**
+     * Обновляет уровень мозга на основе статистики.
+     */
+    private void updateBrainLevel(Villager villager, ServerLevel level) {
+        BrainLevel oldLevel = currentLevel;
+
+        // Принудительное повышение при движении
+        if (ticksAtCurrentPos < STUCK_THRESHOLD && currentLevel.ordinal() > BrainLevel.FULL_BRAIN.ordinal()) {
+            currentLevel = BrainLevel.FULL_BRAIN;
+            stats.reset(); // Новая статистика для нового поведения
+            if (oldLevel != currentLevel) {
+                LOGGER.debug("[HAVB] Villager {} promoted to FULL_BRAIN (moving)", villager.getUUID());
+            }
+            return;
+        }
+
+        // Demotion: долго стоим на месте
+        if (ticksAtCurrentPos > IDLE_THRESHOLD && currentLevel == BrainLevel.FULL_BRAIN) {
+            currentLevel = BrainLevel.SMART_IDLE;
+        }
+
+        if (ticksAtCurrentPos > IDLE_THRESHOLD * 3 && currentLevel == BrainLevel.SMART_IDLE) {
+            if (stats.shouldDemote() || !stats.hasEnoughData()) {
+                currentLevel = BrainLevel.DEEP_LOBOTOMY;
+            }
+        }
+
+        // Promotion: хороший success rate
+        if (currentLevel.ordinal() < BrainLevel.FULL_BRAIN.ordinal() && stats.shouldPromote()) {
+            currentLevel = BrainLevel.values()[currentLevel.ordinal() - 1];
+            if (currentLevel == BrainLevel.FULL_BRAIN) {
+                stats.reset();
+            }
+        }
+
+        if (oldLevel != currentLevel) {
+            LOGGER.debug("[HAVB] Villager {} level change: {} -> {} (streak={}, stats={})",
+                villager.getUUID(), oldLevel, currentLevel, ticksAtCurrentPos, stats);
+        }
+    }
+
+    /**
+     * Регистрирует результат pathfinding для статистики.
+     */
+    public void recordPathfindingResult(boolean reachedDestination) {
+        stats.recordAttempt(reachedDestination);
+    }
+
+    /**
+     * Проверяет, доступна ли рабочая станция (для auto-unlobotomy).
+     */
+    public boolean isWorkstationAccessible(Villager villager, ServerLevel level) {
+        Optional<BlockPos> workstation = villager.getBrain().getMemory(MemoryModuleType.JOB_SITE);
+        if (workstation.isPresent()) {
+            BlockPos pos = workstation.get();
+            BlockState state = level.getBlockState(pos);
+            if (!state.isAir()) {
+                // Проверяем, может ли villager дойти до станции (упрощённо)
+                return villager.distanceToSqr(pos.getX(), pos.getY(), pos.getZ()) < 256; // 16 blocks
+            }
+        }
+        return false;
+    }
+
+    /**
+     * Принудительно сбрасывает уровень (например, при изменении окружения).
+     */
+    public void forceReset() {
+        currentLevel = BrainLevel.FULL_BRAIN;
+        ticksAtCurrentPos = 0;
+        stats.reset();
+        forceRecheck = true;
+    }
+
+    public BrainLevel getCurrentLevel() {
+        return currentLevel;
+    }
+
+    public PathfindingStats getStats() {
+        return stats;
+    }
+
+    @Override
+    public String toString() {
+        return String.format("AdaptiveBrainController[level=%s, ticksAtPos=%d, %s]",
+            currentLevel, ticksAtCurrentPos, stats);
+    }
+}
