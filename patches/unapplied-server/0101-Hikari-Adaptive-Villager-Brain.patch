+                    if (hikariBrainController.isWorkstationAccessible(this, worldserver)) {
+                        hikariBrainController.forceReset(); // Пробуждаемся!
+                    }
+                }
+                
+                this.level().getProfiler().pop();
+                super.customServerAiStep(worldserver);
+                return;
+            }
